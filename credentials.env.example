# Copy this file to `credentials.env` and fill in your real login.
# `credentials.env` is git-ignored and never leaves your machine.

# Quote both values — usernames and passwords can contain spaces.
CM365_USERNAME="your-username"
CM365_PASSWORD="your-password"

# Optional. Defaults to https://clubmanager365.com — only change if your club
# uses a different host or subdomain.
# CM365_BASE_URL="https://clubmanager365.com"

# Optional. Match type used for bookings. Defaults to 4 (= Friendly), but the
# numbering is club-specific — run `cm365 match-types` to find your club's ids.
# CM365_MATCH_TYPE="4"
